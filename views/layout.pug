    block content
    button.theme-toggle(type="button" aria-label="Toggle theme")
      span.theme-toggle-icon ☀
      span.theme-toggle-label Light
    script(src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js")
    script.
      feather.replace({ 'stroke-width': 2 });

      // ---------- Sound: one snappy noise-based click for every interaction ----------
      (function () {
        var ctx = null;
        function getCtx() {
          if (!ctx) {
            try { ctx = new (window.AudioContext || window.webkitAudioContext)(); }
            catch (e) { return null; }
          }
          if (ctx.state === 'suspended') ctx.resume();
          return ctx;
        }
        function noiseBuffer(c, durSec) {
          var len = Math.max(1, Math.floor(durSec * c.sampleRate));
          var buf = c.createBuffer(1, len, c.sampleRate);
          var data = buf.getChannelData(0);
          for (var i = 0; i < len; i++) data[i] = Math.random() * 2 - 1;
          return buf;
        }
        // Real mechanical clicks are broadband noise transients shaped by filters,
        // not tones. Sharper version: shorter, higher-pitched, near-instant attack.
        function playClick() {
          var c = getCtx();
          if (!c) return;
          var t = c.currentTime;
          var dur = 0.006;
          var src = c.createBufferSource();
          src.buffer = noiseBuffer(c, dur);

          var hp = c.createBiquadFilter();
          hp.type = 'highpass';
          hp.frequency.value = 3800;
          hp.Q.value = 0.7;

          var bp = c.createBiquadFilter();
          bp.type = 'bandpass';
          bp.frequency.value = 6800;
          bp.Q.value = 2.2;

          var gain = c.createGain();
          gain.gain.setValueAtTime(0, t);
          gain.gain.linearRampToValueAtTime(0.24, t + 0.0002);
          gain.gain.exponentialRampToValueAtTime(0.0001, t + dur);

          src.connect(hp).connect(bp).connect(gain).connect(c.destination);
          src.start(t);
          src.stop(t + dur + 0.003);
        }

        // Backward-compatible API + simple alias for any callers
        window.fdSound = { click: playClick, switch: playClick, pop: playClick };

        // Single delegated handler for every interactive element on every page.
        // Only fires on real user clicks (e.isTrusted) — skips programmatic
        // clicks like downloadLink.click() inside the Save handler that would
        // otherwise produce a double-tick.
        var INTERACTIVE_SELECTOR =
          'a, button, label[for], .copy-container';
        document.addEventListener('click', function (e) {
          if (!e.isTrusted) return;
          if (!e.target.closest(INTERACTIVE_SELECTOR)) return;
          if (window.fdSound) window.fdSound.click();
          // Haptic on mobile (Android Chrome/Firefox/Brave). No-op on iOS + desktop.
          if (typeof navigator !== 'undefined' && navigator.vibrate) {
            try { navigator.vibrate(8); } catch (e) {}
          }
        }, true);
      })();

      // ---------- Theme toggle with View Transitions + radial reveal + sound ----------
      (function () {
        var saved = localStorage.getItem('flickerdocs-theme');
        if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');

        document.addEventListener('DOMContentLoaded', function () {
          var btn = document.querySelector('.theme-toggle');
          var icon = btn && btn.querySelector('.theme-toggle-icon');
          var label = btn && btn.querySelector('.theme-toggle-label');

          function syncIcon() {
            var dark = document.documentElement.getAttribute('data-theme') === 'dark';
            if (icon) icon.textContent = dark ? '☾' : '☀';
            if (label) label.textContent = dark ? 'Dark' : 'Light';
          }
          syncIcon();

          function flipTheme() {
            var dark = document.documentElement.getAttribute('data-theme') === 'dark';
            if (dark) {
              document.documentElement.removeAttribute('data-theme');
              localStorage.setItem('flickerdocs-theme', 'light');
            } else {
              document.documentElement.setAttribute('data-theme', 'dark');
              localStorage.setItem('flickerdocs-theme', 'dark');
            }
            syncIcon();
          }

          if (!btn) return;

          btn.addEventListener('click', function (e) {
            // Compute click origin for the radial reveal
            var rect = btn.getBoundingClientRect();
            var x = rect.left + rect.width / 2;
            var y = rect.top + rect.height / 2;
            var endRadius = Math.hypot(
              Math.max(x, window.innerWidth - x),
              Math.max(y, window.innerHeight - y)
            );

            // View Transitions API path (modern browsers)
            if (document.startViewTransition) {
              document.documentElement.style.setProperty('--reveal-x', x + 'px');
              document.documentElement.style.setProperty('--reveal-y', y + 'px');
              document.documentElement.style.setProperty('--reveal-r', endRadius + 'px');
              var transition = document.startViewTransition(flipTheme);
              transition.ready
                .then(function () {
                  document.documentElement.animate(
                    [
                      { clipPath: 'circle(0px at ' + x + 'px ' + y + 'px)' },
                      { clipPath: 'circle(' + endRadius + 'px at ' + x + 'px ' + y + 'px)' },
                    ],
                    {
                      duration: 480,
                      easing: 'cubic-bezier(0.4, 0, 0.2, 1)',
                      pseudoElement: '::view-transition-new(root)',
                    }
                  );
                })
                .catch(function () {});
            } else {
              flipTheme();
            }
          });
        });
      })();
    block scripts
